{
    "name": "cline/analyzer",
    "description": "Configurable parallel PHP code analyzer for checking class references",
    "license": "MIT",
    "keywords": [
        "php",
        "analyzer",
        "static-analysis",
        "code-quality",
        "parallel-processing",
        "class-references"
    ],
    "authors": [
        {
            "name": "Brian Faust",
            "email": "brian@cline.sh"
        }
    ],
    "require": {
        "php": "^8.5.0",
        "facade/ignition-contracts": "^1.0.2",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "laravel/prompts": "^0.3.13",
        "nikic/php-parser": "^5.7.0",
        "phpdocumentor/reflection-common": "^2.2",
        "phpdocumentor/reflection-docblock": "^5.6.6",
        "phpdocumentor/type-resolver": "^1.12.0",
        "symfony/process": "^7.4.5"
    },
    "require-dev": {
        "cline/coding-standard": "^2.0.1",
        "ergebnis/composer-normalize": "^2.50.0",
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.9",
        "pestphp/pest": "^4.4.1",
        "pestphp/pest-plugin-laravel": "^4.1",
        "pestphp/pest-plugin-type-coverage": "^4.0.3",
        "spatie/laravel-package-tools": "^1.93.0",
        "symfony/var-dumper": "^6.0 || ^7.4.6"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Cline\\Analyzer\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "ergebnis/composer-normalize": true,
            "pestphp/pest-plugin": true
        },
        "preferred-install": "dist"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Cline\\Analyzer\\AnalyzerServiceProvider"
            ]
        }
    },
    "scripts": {
        "lint": "ecs check --fix",
        "refactor": "rector",
        "test": [
            "@test:lint",
            "@test:type-coverage",
            "@test:unit",
            "@test:types",
            "@test:refactor"
        ],
        "test:lint": "ecs check",
        "test:refactor": "rector --dry-run",
        "test:type-coverage": "php -d memory_limit=512M vendor/bin/pest --parallel --min=80 --type-coverage",
        "test:types": "phpstan --memory-limit=512M",
        "test:unit": "pest --parallel --coverage"
    }
}
